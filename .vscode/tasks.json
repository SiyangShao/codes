{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C/C++: g++ build active file",
            "type": "shell",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true,
            },
            "command": "g++",
            "args": [
                "-g",
                "${fileBasename}",
                "-o",
                //"${fileBasenameNoExtension}",
                "a.out",
            ],
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}